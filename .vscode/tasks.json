{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Refresh dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run idempotency tests (suite)",
      "type": "shell",
      "command": "npx vitest run --project unit lib/api/idempotency.test.ts app/api/auth/session/route.test.ts app/api/transactions/route.test.ts --coverage.enabled false",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
